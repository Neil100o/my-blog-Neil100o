---
import Layout from '../layouts/BlogPost.astro';
import { getCollection } from 'astro:content';

const secretPosts = await getCollection('hidden');
---

<Layout title="秘密空间">
  <main style="max-width:800px;margin:0 auto;padding:2rem 1rem;">
    <h1 style="border-bottom:3px solid #cc0000;padding-bottom:0.5rem;margin-bottom:1rem;">🎴 秘密空间</h1>
    <p style="color:#666;margin-bottom:2rem;font-style:italic;">"嘘，别乱说哦"</p>

    {secretPosts.length === 0 && <p style="color:#999;">这里还没有秘密...</p>}

    <div style="display:flex;flex-direction:column;gap:1.5rem;">
      {secretPosts.map(post => (
        <article style="border-bottom:1px solid #eee;padding-bottom:1.5rem;">
          <a href={`/secret/${post.id}/`} style="font-size:1.3rem;font-weight:800;text-decoration:none;color:#000;border-bottom:none;">{post.data.title}</a>
          <p style="color:#666;margin:0.5rem 0;">{post.data.description}</p>
          <small style="color:#999;font-weight:600;">{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</small>
        </article>
      ))}
    </div>

    <div style="margin-top:3rem;text-align:center;">
      <a href="/" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;border:2px solid #000;font-weight:700;text-decoration:none;">← 返回地面</a>
    </div>
  </main>
</Layout>