---
import Layout from '../layouts/BlogPost.astro';

// 直接用 Vite 的 import.meta.glob 读取 hidden 目录下的所有 .md 文件
const modules = import.meta.glob('../content/hidden/**/*.md', { eager: true });

// 解析成和 getCollection 类似的结构
const secretPosts = Object.entries(modules).map(([filePath, mod]) => {
  // 从路径提取 id，如 /hidden/loveorsomething.md → loveorsomething
  const id = filePath.replace(/.*\/hidden\/(.*)\.md$/, '$1');
  return {
    id,
    data: mod.frontmatter,
  };
}).sort((a, b) => {
  const dateA = new Date(a.data.pubDate || 0);
  const dateB = new Date(b.data.pubDate || 0);
  return dateB.valueOf() - dateA.valueOf();
});
---

<Layout title="秘密空间">
  <main style="max-width:960px;margin:0 auto;padding:2rem 1rem;">
    <h1 style="border-bottom:3px solid #cc0000;padding-bottom:0.5rem;margin-bottom:1rem;">🎴 秘密空间</h1>
    <p style="color:#666;margin-bottom:2rem;font-style:italic;">"嘘，别乱说哦"</p>

    {secretPosts.length === 0 && <p style="color:#999;">这里还没有秘密...</p>}

    <ul style="display:flex;flex-wrap:wrap;gap:2rem;list-style:none;margin:0;padding:0;">
      {secretPosts.map((post, index) => (
        <li style={`width: ${index === 0 ? '100%' : 'calc(50% - 1rem)'}; margin-bottom: 1rem;`}>
          <a href={`/secret/${post.id}/`} style="display:block;text-decoration:none;color:#000;">
            {post.data.heroImage && (
              <img 
                src={post.data.heroImage} 
                alt="" 
                style={`width:100%;border-radius:12px;margin-bottom:0.5rem;${index === 0 ? 'max-height:400px;object-fit:cover;' : ''}`}
              />
            )}
            <h4 style="margin:0;font-size:${index === 0 ? '2.369rem' : '1.2rem'};line-height:1;">{post.data.title}</h4>
            <p style="margin:0.3rem 0 0;color:rgb(var(--gray));">
              {post.data.pubDate && new Date(post.data.pubDate).toLocaleDateString('zh-CN')}
            </p>
          </a>
        </li>
      ))}
    </ul>

    <div style="margin-top:3rem;text-align:center;">
      <a href="/" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;border:2px solid #000;font-weight:700;text-decoration:none;">← 返回地面</a>
    </div>
  </main>
</Layout>