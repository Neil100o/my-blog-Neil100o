---
import Layout from '../../layouts/BlogPost.astro';
---

<Layout title="评论与日志">
  <div id="auth-overlay" style="position:fixed;top:0;left:0;width:100%;height:100%;background:#fff;z-index:9999;display:flex;align-items:center;justify-content:center;">
  <div style="border:3px solid #000;padding:2rem;max-width:400px;width:90%;">
    <h2 style="margin:0 0 1.5rem 0;border-bottom:3px solid #cc0000;padding-bottom:0.5rem;">🔒 评论与日志</h2>
    <p style="margin:0 0 1rem 0;color:#666;">请输入密码进入</p>
    <input type="password" id="auth-pwd" placeholder="密码" style="width:100%;padding:0.7rem;border:2px solid #000;font-size:1rem;margin-bottom:1rem;" />
    <button id="auth-btn" style="width:100%;padding:0.8rem;background:#000;color:#fff;border:2px solid #000;font-weight:800;cursor:pointer;">进入</button>
  </div>
</div>

<main id="admin-main" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; display: none;">
    <div style="display:none;">
      <input type="password" id="admin-pwd" style="display:none;" />
    </div>
    <h1 style="border-bottom: 3px solid #000; padding-bottom: 0.5rem; margin-bottom: 2rem;">💬 评论与日志</h1>
    
    <div style="display:flex;gap:0.5rem;margin-bottom:2rem;border-bottom:2px solid #000;padding-bottom:0.5rem;flex-wrap:wrap;">
      <a href="/admin" style="padding:0.5rem 1rem;background:#fff;color:#000;border:2px solid #000;text-decoration:none;font-weight:800;">✎ 发布</a>
      <a href="/admin/posts" style="padding:0.5rem 1rem;background:#fff;color:#000;border:2px solid #000;text-decoration:none;font-weight:800;">📄 文章</a>
      <a href="/admin/comments" style="padding:0.5rem 1rem;background:#000;color:#fff;text-decoration:none;font-weight:800;">💬 评论</a>
    </div>
    
    <div id="comment-list" style="padding: 1.5rem; border: 2px solid #000;">
      <h2 style="border-bottom: 2px solid #cc0000; padding-bottom: 0.5rem; margin-bottom: 1rem;">💬 评论管理</h2>
      <div id="comments-loading">加载中...</div>
      <div id="comments-container"></div>
    </div>
    
    <div id="access-log" style="margin-top: 2rem; padding: 1.5rem; border: 2px solid #000;">
      <div style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;" onclick="toggleAccessLog()">
        <h2 style="border-bottom: 2px solid #cc0000; padding-bottom: 0.5rem; margin-bottom: 0; margin-top: 0;">📊 访问日志</h2>
        <button id="access-toggle-btn" style="padding:0.3rem 0.8rem;background:#000;color:#fff;border:none;cursor:pointer;font-weight:700;font-size:0.85rem;min-height:36px;">展开 ▼</button>
      </div>
      <div id="access-content" style="display:none;margin-top:1rem;">
        <div id="access-loading">加载中...</div>
        <div id="access-container"></div>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function() {
    var overlay = document.getElementById('auth-overlay');
    var main = document.getElementById('admin-main');
    var authPwd = document.getElementById('auth-pwd');
    var authBtn = document.getElementById('auth-btn');
    var pwdInput = document.getElementById('admin-pwd');

    var storedPwd = sessionStorage.getItem('adminPwd');
    if (storedPwd) {
      overlay.style.display = 'none';
      main.style.display = 'block';
      if (pwdInput) pwdInput.value = storedPwd;
      loadComments();
      return;
    }

    function doAuth() {
      var pwd = authPwd.value.trim();
      if (!pwd) { alert('请输入密码'); return; }
      authBtn.disabled = true;
      authBtn.textContent = '验证中...';
      fetch('/api/verify-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwd })
      })
      .then(function(r) {
        if (!r.ok) throw new Error('密码错误');
        return r.json();
      })
      .then(function() {
        sessionStorage.setItem('adminPwd', pwd);
        overlay.style.display = 'none';
        main.style.display = 'block';
        loadComments();
      })
      .catch(function() {
        alert('密码错误');
        authPwd.value = '';
        authPwd.focus();
        authBtn.disabled = false;
        authBtn.textContent = '进入';
      });
    }

    authBtn.addEventListener('click', doAuth);
    authPwd.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') doAuth();
    });
    authPwd.focus();
  })();

  // 加载评论列表
  function loadComments() {
    var container = document.getElementById('comments-container');
    var loading = document.getElementById('comments-loading');
    var pwdInput = document.getElementById('admin-pwd');
    if (!pwdInput || !pwdInput.value) return;
    fetch('/api/admin-comments?password=' + encodeURIComponent(pwdInput.value))
      .then(function(r) {
        if (!r.ok) throw new Error('加载失败');
        return r.json();
      })
      .then(function(d) {
        loading.style.display = 'none';
        if (!d || !d.length) {
          container.innerHTML = '<p style="color:#999">暂无评论</p>';
          return;
        }
        var html = '<div style="display:flex;flex-direction:column;gap:0.5rem;">';
        for (var i = 0; i < d.length; i++) {
          var c = d[i];
          var replyLabel = c.parent_id ? '<span style="background:#cc0000;color:#fff;padding:0.1rem 0.4rem;font-size:0.75rem;margin-right:0.5rem;">回复</span>' : '';
          html += '<div style="padding:0.8rem;border:1px solid #e0e0e0;">' +
            '<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">' +
              '<div><strong>' + c.author + '</strong> <small style="color:#999">' + (c.email || '') + '</small>' + replyLabel + '</div>' +
              '<small style="color:#999">' + new Date(c.created_at).toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai', hour12: false }) + '</small>' +
            '</div>' +
            '<div style="margin:0.3rem 0;color:#666;font-size:0.85rem;"><a href="' + c.path + '" target="_blank" style="color:#cc0000;">' + c.path + '</a></div>' +
            '<p style="margin:0.5rem 0;white-space:pre-wrap;font-size:0.95rem;">' + c.content + '</p>' +
            '<button class="del-comment-btn" data-id="' + c.id + '" style="padding:0.3rem 0.8rem;background:#cc0000;color:#fff;border:none;cursor:pointer;font-weight:700;font-size:0.9rem;min-height:36px;">删除</button>' +
          '</div>';
        }
        html += '</div>';
        container.innerHTML = html;
      })
      .catch(function() {
        loading.textContent = '加载失败';
      });
  }

  document.getElementById('comments-container').addEventListener('click', function(e) {
    if (e.target.classList.contains('del-comment-btn')) {
      var id = e.target.getAttribute('data-id');
      if (!confirm('确定删除这条评论吗？')) return;
      e.target.disabled = true;
      e.target.textContent = '删除中...';
      var pwdInput = document.getElementById('admin-pwd');
      fetch('/api/admin-comments', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(id), password: pwdInput.value })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.success) throw new Error(data.error);
        e.target.parentElement.remove();
      })
      .catch(function(err) {
        alert('删除失败: ' + err.message);
        e.target.disabled = false;
        e.target.textContent = '删除';
      });
    }
  });

  function toggleAccessLog() {
    var content = document.getElementById('access-content');
    var btn = document.getElementById('access-toggle-btn');
    if (content.style.display === 'none') {
      content.style.display = 'block';
      btn.textContent = '收起 ▲';
      if (!content.getAttribute('data-loaded')) {
        content.setAttribute('data-loaded', 'true');
        loadAccessLogs();
      }
    } else {
      content.style.display = 'none';
      btn.textContent = '展开 ▼';
    }
  }

  // 加载访问日志
  function loadAccessLogs() {
    var container = document.getElementById('access-container');
    var loading = document.getElementById('access-loading');
    var pwdInput = document.getElementById('admin-pwd');
    if (!pwdInput || !pwdInput.value) return;
    fetch('/api/log-access?password=' + encodeURIComponent(pwdInput.value))
      .then(function(r) {
        if (!r.ok) throw new Error('加载失败');
        return r.json();
      })
      .then(function(d) {
        loading.style.display = 'none';
        if (!d || !d.length) {
          container.innerHTML = '<p style="color:#999">暂无访问记录</p>';
          return;
        }
        var html = '<div style="display:flex;flex-direction:column;gap:0.5rem;">';
        for (var i = 0; i < d.length; i++) {
          var log = d[i];
          var ua = log.user_agent || '';
          var device = ua.includes('Mobile') ? '📱' : (ua.includes('iPad') ? '💻' : '🖥️');
          html += '<div style="padding:0.6rem;border:1px solid #e0e0e0;">' +
            '<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;">' +
              '<div><strong>' + device + '</strong> ' + (log.country || '未知') + '</div>' +
              '<small style="color:#999">' + new Date(log.created_at).toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai', hour12: false }) + '</small>' +
            '</div>' +
            '<div style="margin:0.2rem 0;color:#666;font-size:0.85rem;"><a href="' + log.path + '" target="_blank" style="color:#cc0000;">' + log.path + '</a></div>' +
            '<small style="color:#999;font-size:0.75rem;">' + ua.substring(0, 80) + (ua.length > 80 ? '...' : '') + '</small>' +
          '</div>';
        }
        html += '</div>';
        container.innerHTML = html;
      })
      .catch(function() {
        loading.textContent = '加载失败';
      });
  }
</script>