---
import Layout from '../../layouts/BlogPost.astro';

// 告诉 Astro 需要为哪些 slug 生成静态页面
export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/hidden/**/*.md', { eager: true });
  
  return Object.entries(modules).map(([filePath, mod]) => {
    const slug = filePath.replace(/.*\/hidden\/(.*)\.md$/, '$1');
    return {
      params: { slug },
      props: { frontmatter: mod.frontmatter }
    };
  });
}

const { slug } = Astro.params;
const { frontmatter } = Astro.props;

// 再次获取对应的 Content 组件
const modules = import.meta.glob('../../content/hidden/**/*.md', { eager: true });
let PostContent = null;
for (const [filePath, mod] of Object.entries(modules)) {
  const id = filePath.replace(/.*\/hidden\/(.*)\.md$/, '$1');
  if (id === slug) {
    PostContent = mod.default;
    break;
  }
}
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <article style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
    {frontmatter.heroImage && (
      <img src={frontmatter.heroImage} alt="" style="width: 100%; border-radius: 12px; margin-bottom: 1.5rem;" />
    )}
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{frontmatter.title}</h1>
    <p style="color: #666; margin-bottom: 2rem;">
      {frontmatter.pubDate && new Date(frontmatter.pubDate).toLocaleDateString('zh-CN')}
    </p>
    <div style="line-height: 1.8; font-size: 1.1rem;">
      {PostContent ? <PostContent /> : <p>内容加载失败</p>}
    </div>
    <div style="margin-top: 3rem; text-align: center;">
      <a href="/secret" style="display: inline-block; padding: 0.6rem 1.5rem; background: #000; color: #fff; text-decoration: none; font-weight: 700;">← 返回秘密空间</a>
    </div>
  </article>
</Layout>