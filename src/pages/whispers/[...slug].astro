---
import { readdir } from 'node:fs/promises';
import Comments from '../../components/Comments.astro';
import SecretLoader from '../../components/SecretLoader.astro';
import Layout from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const entries = await readdir('./src/content/hidden', {
    withFileTypes: true,
  });

  return entries
    .filter((entry) => entry.isFile() && entry.name.endsWith('.md'))
    .map((entry) => ({
      params: { slug: entry.name.slice(0, -3) },
    }));
}

const { slug = '' } = Astro.params;
---

<Layout
  title="秘密文章"
  description="需要秘钥才能访问"
  showComments={false}
  noindex={true}
>
  <SecretLoader id="article-permission-check" label="正在确认权限并接收文章" />

  <div id="whispers-content" style="max-width:800px;margin:0 auto;padding:2rem 1rem;display:none;">
    <img id="secret-hero" src="" alt="" width="1020" height="510" loading="eager" decoding="async" fetchpriority="high" style="width:100%;height:auto;border-radius:12px;margin-bottom:1.5rem;display:none;" />
    <h1 id="secret-title" style="font-size:2.5rem;margin-bottom:0.5rem;"></h1>
    <p id="secret-date" style="color:#666;margin-bottom:2rem;"></p>
    <div id="secret-body" style="line-height:1.8;font-size:1.1rem;"></div>

    <div style="margin-top:3rem;text-align:center;">
      <a href="/whispers" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;text-decoration:none;font-weight:700;">← 返回秘密空间</a>
    </div>

    <div id="secret-comments">
      <hr style="margin:3rem 0;" />
      <Comments />
    </div>
  </div>

  <div id="whispers-blocked" style="max-width:600px;margin:4rem auto;padding:2rem 1rem;text-align:center;display:none;">
    <h1 style="border-bottom:3px solid #cc0000;padding-bottom:0.5rem;margin-bottom:1.5rem;">止步</h1>
    <p style="color:#666;margin-bottom:2rem;">此路不通。</p>
    <a href="/" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;border:2px solid #000;font-weight:700;text-decoration:none;">← 返回首页</a>
  </div>
</Layout>

<script src="/js/secret-space.js" defer></script>
<script src="/js/comments.js" defer></script>
<script is:inline define:vars={{ slug }}>
document.addEventListener('DOMContentLoaded', function() {
  var content = document.getElementById('whispers-content');
  var blocked = document.getElementById('whispers-blocked');
  var permissionCheck = document.getElementById('article-permission-check');
  var title = document.getElementById('secret-title');
  var date = document.getElementById('secret-date');
  var body = document.getElementById('secret-body');
  var hero = document.getElementById('secret-hero');

  function showBlocked() {
    permissionCheck.style.display = 'none';
    content.style.display = 'none';
    blocked.style.display = 'block';
  }

  window.SecretSpace.fetchJson('/api/secret-post?slug=' + encodeURIComponent(slug))
    .then(function(data) {
      var post = data.post;
      if (!post) throw new Error('Article missing');

      title.textContent = post.title || '秘密文章';
      document.title = (post.title || '秘密文章') + ' | Mo Blog';
      date.textContent = post.pubDate ? new Date(post.pubDate).toLocaleDateString('zh-CN') : '';
      body.innerHTML = window.SecretSpace.renderMarkdown(post.markdown || '');

      var heroUrl = window.SecretSpace.safeUrl(post.heroImage);
      if (heroUrl) {
        hero.src = heroUrl;
        hero.style.display = 'block';
      }

      permissionCheck.style.display = 'none';
      blocked.style.display = 'none';
      content.style.display = 'block';
    })
    .catch(function(error) {
      if (error && error.status === 401) {
        showBlocked();
        return;
      }
      var loaderCode = permissionCheck.querySelector('.loader-code');
      var loaderLabel = permissionCheck.querySelector('.loader-label');
      if (loaderCode) loaderCode.textContent = 'SIGNAL LOST';
      if (loaderLabel) loaderLabel.textContent = '文章接收失败，请刷新后重试';
    });
});
</script>
