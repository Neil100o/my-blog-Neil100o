---
import Layout from '../../layouts/BlogPost.astro';

// 告诉 Astro 需要为哪些 slug 生成静态页面
export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/hidden/**/*.md', { eager: true });
  
  return Object.entries(modules).map(([filePath, mod]) => {
    const slug = filePath.replace(/.*\/hidden\/(.*)\.md$/, '$1');
    return {
      params: { slug },
      props: { frontmatter: mod.frontmatter }
    };
  });
}

const { slug } = Astro.params;
const { frontmatter } = Astro.props;

// 再次获取对应的 Content 组件
const modules = import.meta.glob('../../content/hidden/**/*.md', { eager: true });
let PostContent = null;
for (const [filePath, mod] of Object.entries(modules)) {
  const id = filePath.replace(/.*\/hidden\/(.*)\.md$/, '$1');
  if (id === slug) {
    PostContent = mod.default;
    break;
  }
}
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <!-- 有权限：显示内容 -->
  <div id="whispers-content" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; display: none;">
    {frontmatter.heroImage && (
      <img src={frontmatter.heroImage} alt="" style="width: 100%; border-radius: 12px; margin-bottom: 1.5rem;" />
    )}
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{frontmatter.title}</h1>
    <p style="color: #666; margin-bottom: 2rem;">
      {frontmatter.pubDate && new Date(frontmatter.pubDate).toLocaleDateString('zh-CN')}
    </p>
    <div style="line-height: 1.8; font-size: 1.1rem;">
      {PostContent ? <PostContent /> : <p>内容加载失败</p>}
    </div>
    <div style="margin-top: 3rem; text-align: center;">
      <a href="/whispers" style="display: inline-block; padding: 0.6rem 1.5rem; background: #000; color: #fff; text-decoration: none; font-weight: 700;">← 返回秘密空间</a>
    </div>
  </div>

  <!-- 无权限：止步 -->
  <div id="whispers-blocked" style="max-width:600px;margin:4rem auto;padding:2rem 1rem;text-align:center; display:none;">
    <h1 style="border-bottom:3px solid #cc0000;padding-bottom:0.5rem;margin-bottom:1.5rem;">止步</h1>
    <p style="color:#666;margin-bottom:2rem;">此路不通。</p>
    <a href="/" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;border:2px solid #000;font-weight:700;text-decoration:none;">← 返回首页</a>
  </div>
</Layout>

<script is:inline>
(function() {
  var SECRET_KEY = 'sk_';
  var key = sessionStorage.getItem(SECRET_KEY) || localStorage.getItem(SECRET_KEY);
  
  if (!key) {
    document.getElementById('whispers-content').style.display = 'none';
    document.getElementById('whispers-blocked').style.display = 'block';
  } else {
    // 验证 key 是否有效
    fetch('/api/secret-check?key=' + encodeURIComponent(key))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.valid) {
          document.getElementById('whispers-content').style.display = 'block';
          document.getElementById('whispers-blocked').style.display = 'none';
        } else {
          sessionStorage.removeItem(SECRET_KEY);
          localStorage.removeItem(SECRET_KEY);
          document.getElementById('whispers-content').style.display = 'none';
          document.getElementById('whispers-blocked').style.display = 'block';
        }
      })
      .catch(function() {
        document.getElementById('whispers-content').style.display = 'none';
        document.getElementById('whispers-blocked').style.display = 'block';
      });
  }
})();
</script>
