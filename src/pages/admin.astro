---
import Layout from '../layouts/BlogPost.astro';
---

<Layout title="写作后台">
  <main style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
    <h1 style="border-bottom: 3px solid #000; padding-bottom: 0.5rem; margin-bottom: 2rem;">✎ 写作后台</h1>
    
    <form id="post-form" style="display: flex; flex-direction: column; gap: 1.2rem;">
      <div style="background: #000; color: #fff; padding: 1rem 1.2rem; display: flex; align-items: center; gap: 1rem;">
        <label style="font-weight: 800; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; white-space: nowrap;">🔒 发布密码</label>
        <input type="password" id="admin-pwd" required style="flex: 1; padding: 0.5rem; border: 2px solid #cc0000; background: #fff; color: #000; font-size: 1rem;" />
      </div>
      
      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">标题</label>
        <input type="text" id="title" required style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-size: 1.1rem;" />
      </div>
      
      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">Slug（URL 路径）</label>
        <input type="text" id="slug" placeholder="留空自动从标题生成，如 my-first-post" style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-size: 1rem;" />
        <small style="color: #666;">最终链接：https://moblog-aa5.pages.dev/blog/你的slug/</small>
      </div>
      
      <div style="display: flex; gap: 1rem;">
        <div style="flex: 1;">
          <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">日期</label>
          <input type="date" id="date" required style="width: 100%; padding: 0.7rem; border: 2px solid #000;" />
        </div>
        <div style="flex: 1;">
          <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">标签</label>
          <input type="text" id="tags" placeholder="随笔, 技术, 生活" style="width: 100%; padding: 0.7rem; border: 2px solid #000;" />
        </div>
      </div>
      
      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">内容（Markdown）</label>
        <textarea id="content" rows="20" required style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-family: 'SF Mono', Monaco, monospace; font-size: 0.95rem; line-height: 1.7; resize: vertical;"></textarea>
      </div>
      
      <div style="display: flex; gap: 1rem;">
        <button type="button" id="preview-btn" style="flex: 1; padding: 0.9rem; background: #fff; color: #000; border: 2px solid #000; font-weight: 800; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;">👁 预览</button>
        <button type="submit" style="flex: 1; padding: 0.9rem; background: #cc0000; color: #fff; border: 2px solid #cc0000; font-weight: 800; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;">🚀 发布</button>
      </div>
    </form>
    
    <div id="preview" style="margin-top: 2rem; padding: 2rem; border: 2px solid #000; display: none;">
      <h2 style="border-bottom: 2px solid #cc0000; padding-bottom: 0.5rem; margin-bottom: 1rem;">预览</h2>
      <div id="preview-content" style="line-height: 1.8;"></div>
    </div>
    
    <div id="status" style="margin-top: 1.5rem; padding: 1.2rem; display: none; border: 2px solid #000;"></div>
  </main>
</Layout>

<script is:inline>
  document.getElementById('date').valueAsDate = new Date();
  
  const textarea = document.getElementById('content');
  
  // Tab 键支持
  textarea.addEventListener('keydown', (e) => {
    if (e.key === 'Tab') {
      e.preventDefault();
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      textarea.value = textarea.value.substring(0, start) + '  ' + textarea.value.substring(end);
      textarea.selectionStart = textarea.selectionEnd = start + 2;
    }
  });
  
  // 预览
  document.getElementById('preview-btn').addEventListener('click', () => {
    const content = textarea.value;
    const preview = document.getElementById('preview');
    const previewContent = document.getElementById('preview-content');
    
    let html = content
      .replace(/^### (.*$)/gim, '<h3>$1</h3>')
      .replace(/^## (.*$)/gim, '<h2>$1</h2>')
      .replace(/^# (.*$)/gim, '<h1>$1</h1>')
      .replace(/\*\*(.*)\*\*/gim, '<b>$1</b>')
      .replace(/\*(.*)\*/gim, '<i>$1</i>')
      .replace(/`([^`]+)`/gim, '<code style="background:#f0f0f0;padding:0.2rem 0.4rem;color:#cc0000;">$1</code>')
      .replace(/```([\s\S]*?)```/gim, '<pre style="background:#0a0a0a;color:#fff;padding:1rem;overflow-x:auto;border-left:4px solid #cc0000;"><code>$1</code></pre>')
      .replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2" style="color:#cc0000;border-bottom:1px solid #cc0000;">$1</a>')
      .replace(/^> (.*$)/gim, '<blockquote>$1</blockquote>')
      .replace(/^- (.*$)/gim, '<li>$1</li>')
      .replace(/\n/gim, '<br>');
    
    previewContent.innerHTML = html;
    preview.style.display = 'block';
    preview.scrollIntoView({ behavior: 'smooth' });
  });
  
  function generateSlug(title) {
    return title.toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-')
      .substring(0, 50);
  }
  
  document.getElementById('post-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('status');
    const btn = e.target.querySelector('button[type="submit"]');
    
    const title = document.getElementById('title').value.trim();
    let slug = document.getElementById('slug').value.trim() || generateSlug(title);
    const date = document.getElementById('date').value;
    const tags = document.getElementById('tags').value.split(',').map(t => t.trim()).filter(t => t);
    const content = textarea.value;
    const password = document.getElementById('admin-pwd').value;
    
    if (!slug.endsWith('.md')) slug += '.md';
    
    btn.disabled = true;
    btn.textContent = '发布中...';
    status.style.display = 'block';
    status.style.background = '#f5f5f5';
    status.style.color = '#000';
    status.innerHTML = '正在提交到 GitHub...';
    
    try {
      const res = await fetch('/api/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, slug, date, tags, content, password })
      });
      
      const data = await res.json();
      
      if (!res.ok) throw new Error(data.error || '发布失败');
      
      status.style.background = '#000';
      status.style.color = '#fff';
      status.innerHTML = `✅ 发布成功！<<br>文件路径：${data.path}<br>Cloudflare 正在自动构建，约 1-2 分钟后上线。<br><a href="/blog/${slug.replace('.md', '')}/" style="color:#cc0000;">→ 查看文章</a>`;
      
      e.target.reset();
      document.getElementById('date').valueAsDate = new Date();
      document.getElementById('preview').style.display = 'none';
    } catch (err) {
      status.style.background = '#cc0000';
      status.style.color = '#fff';
      status.innerHTML = `❌ 错误：${err.message}<br><small style="opacity:0.8;">检查密码是否正确，或 GitHub Token 是否已绑定</small>`;
    } finally {
      btn.disabled = false;
      btn.textContent = '🚀 发布';
    }
  });
</script>