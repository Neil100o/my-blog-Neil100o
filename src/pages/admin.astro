---
import Layout from '../layouts/BlogPost.astro';
---

<Layout title="写作后台">
  <div id="auth-overlay" style="position:fixed;top:0;left:0;width:100%;height:100%;background:#fff;z-index:9999;display:flex;align-items:center;justify-content:center;">
  <div style="border:3px solid #000;padding:2rem;max-width:400px;width:90%;">
    <h2 style="margin:0 0 1.5rem 0;border-bottom:3px solid #cc0000;padding-bottom:0.5rem;">🔒 写作后台</h2>
    <p style="margin:0 0 1rem 0;color:#666;">请输入密码进入</p>
    <input type="password" id="auth-pwd" placeholder="密码" style="width:100%;padding:0.7rem;border:2px solid #000;font-size:1rem;margin-bottom:1rem;" />
    <button id="auth-btn" style="width:100%;padding:0.8rem;background:#000;color:#fff;border:2px solid #000;font-weight:800;cursor:pointer;">进入</button>
  </div>
</div>

<main id="admin-main" style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; display: none;">
    <h1 style="border-bottom: 3px solid #000; padding-bottom: 0.5rem; margin-bottom: 2rem;">✎ 写作后台</h1>
    
    <div style="display:flex;gap:0.5rem;margin-bottom:2rem;border-bottom:2px solid #000;padding-bottom:0.5rem;flex-wrap:wrap;">
      <a href="/admin" style="padding:0.5rem 1rem;background:#000;color:#fff;text-decoration:none;font-weight:800;">✎ 发布</a>
      <a href="/admin/posts" style="padding:0.5rem 1rem;background:#fff;color:#000;border:2px solid #000;text-decoration:none;font-weight:800;">📄 文章</a>
      <a href="/admin/comments" style="padding:0.5rem 1rem;background:#fff;color:#000;border:2px solid #000;text-decoration:none;font-weight:800;">💬 评论</a>
    </div>
    
    <form id="post-form" style="display: flex; flex-direction: column; gap: 1.2rem;">
      <div style="display:none;">
        <input type="password" id="admin-pwd" style="display:none;" />
      </div>
      
      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">标题</label>
        <input type="text" id="title" required style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-size: 1.1rem;" />
      </div>
      
      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">Slug（URL 路径）</label>
        <input type="text" id="slug" placeholder="留空自动从标题生成，如 my-first-post" style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-size: 1rem;" />
        <small style="color: #666;">最终链接：https://moblog-aa5.pages.dev/blog/你的slug/</small>
      </div>
      
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 240px;">
          <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">发布时间</label>
          <div id="publish-time-display" style="padding: 0.7rem; border: 2px solid #000; background: #f5f5f5; color: #666; font-size: 0.95rem;">加载中...</div>
          <input type="hidden" id="date" />
        </div>
        <div style="flex: 1; min-width: 240px;">
          <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">标签</label>
          <input type="text" id="tags" placeholder="随笔, 技术, 生活" style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-size: 1rem;" />
        </div>
      </div>

      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">顶图链接（可选）</label>
        <input type="text" id="heroImage" placeholder="粘贴图片外链，如 https://cdn.jsdelivr.net/gh/..." style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-size: 1rem;" />
        <small style="color: #666;">上传图片后会自动填入第一张图的链接</small>
      </div>

        <div style="display: flex; align-items: center; gap: 0.5rem; margin: 0.5rem 0;">
        <input type="checkbox" id="hidden" style="width: 1.2rem; height: 1.2rem; accent-color: #cc0000; cursor: pointer;" />
        <label for="hidden" style="font-weight: 700; font-size: 0.9rem; cursor: pointer;">🚪 隐藏文章（不显示在博客列表，只能通过彩蛋或直链访问）</label>
      </div>

      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">图片</label>
        <input type="file" id="image-input" accept="image/*" multiple style="display: none;" />
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;">
          <button type="button" id="upload-btn" style="padding: 0.6rem 1.2rem; background: #000; color: #fff; border: 2px solid #000; font-weight: 700; cursor: pointer; font-size: 1rem; min-height: 44px;">📎 选择图片</button>
          <span id="upload-status" style="color: #666; font-size: 0.9rem;"></span>
        </div>
        <div id="image-preview" style="display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap;"></div>
        <small style="color: #666;">支持多选，自动压缩并插入 Markdown，单张建议不超过 10MB</small>
      </div>
      
      <div>
        <label style="display: block; font-weight: 800; margin-bottom: 0.4rem; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">内容（Markdown）</label>
        <textarea id="content" rows="12" required style="width: 100%; padding: 0.7rem; border: 2px solid #000; font-family: 'SF Mono', Monaco, monospace; font-size: 16px; line-height: 1.7; resize: vertical;"></textarea>
      </div>
      
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <button type="button" id="preview-btn" style="flex: 1; min-width: 120px; padding: 0.9rem; background: #fff; color: #000; border: 2px solid #000; font-weight: 800; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; font-size: 1rem; min-height: 48px;">👁 预览</button>
        <button type="submit" style="flex: 1; min-width: 120px; padding: 0.9rem; background: #cc0000; color: #fff; border: 2px solid #cc0000; font-weight: 800; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; font-size: 1rem; min-height: 48px;">🚀 发布</button>
      </div>
    </form>

    <div id="preview" style="margin-top: 2rem; padding: 2rem; border: 2px solid #000; display: none;">
      <h2 style="border-bottom: 2px solid #cc0000; padding-bottom: 0.5rem; margin-bottom: 1rem;">预览</h2>
      <div id="preview-content" style="line-height: 1.8;"></div>
    </div>
    
    <div id="status" style="margin-top: 1.5rem; padding: 1.2rem; display: none; border: 2px solid #000;"></div>
  </main>
</Layout>

<script is:inline>
  (function() {
    var overlay = document.getElementById('auth-overlay');
    var main = document.getElementById('admin-main');
    var authPwd = document.getElementById('auth-pwd');
    var authBtn = document.getElementById('auth-btn');
    var adminPwdInput = document.getElementById('admin-pwd');

    var storedPwd = sessionStorage.getItem('adminPwd');
    if (storedPwd) {
      overlay.style.display = 'none';
      main.style.display = 'block';
      adminPwdInput.value = storedPwd;
      return;
    }

    function doAuth() {
      var pwd = authPwd.value.trim();
      if (!pwd) { alert('请输入密码'); return; }
      authBtn.disabled = true;
      authBtn.textContent = '验证中...';
      fetch('/api/verify-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwd })
      })
      .then(function(r) {
        if (!r.ok) throw new Error('密码错误');
        return r.json();
      })
      .then(function() {
        sessionStorage.setItem('adminPwd', pwd);
        adminPwdInput.value = pwd;
        overlay.style.display = 'none';
        main.style.display = 'block';
      })
      .catch(function() {
        alert('密码错误');
        authPwd.value = '';
        authPwd.focus();
        authBtn.disabled = false;
        authBtn.textContent = '进入';
      });
    }

    authBtn.addEventListener('click', doAuth);
    authPwd.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') doAuth();
    });
    authPwd.focus();
  })();

  function updatePublishTime() {
    var now = new Date();
    document.getElementById('date').value = now.toISOString();
    document.getElementById('publish-time-display').textContent = now.toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai', hour12: false });
  }
  updatePublishTime();

  var textarea = document.getElementById('content');
  var pwdInput = document.getElementById('admin-pwd');
  
  // Tab 键支持
  textarea.addEventListener('keydown', function(e) {
    if (e.key === 'Tab') {
      e.preventDefault();
      var start = textarea.selectionStart;
      var end = textarea.selectionEnd;
      textarea.value = textarea.value.substring(0, start) + '  ' + textarea.value.substring(end);
      textarea.selectionStart = textarea.selectionEnd = start + 2;
    }
  });
  
  // 预览
  document.getElementById('preview-btn').addEventListener('click', function() {
    var content = textarea.value;
    var preview = document.getElementById('preview');
    var previewContent = document.getElementById('preview-content');
    
    var html = content
      .replace(/^### (.*$)/gim, '<h3>$1</h3>')
      .replace(/^## (.*$)/gim, '<h2>$1</h2>')
      .replace(/^# (.*$)/gim, '<h1>$1</h1>')
      .replace(/\*\*(.*)\*\*/gim, '<b>$1</b>')
      .replace(/\*(.*)\*/gim, '<i>$1</i>')
      .replace(/`([^`]+)`/gim, '<code style="background:#f0f0f0;padding:0.2rem 0.4rem;color:#cc0000;">$1</code>')
      .replace(/```([\s\S]*?)```/gim, '<pre style="background:#0a0a0a;color:#fff;padding:1rem;overflow-x:auto;border-left:4px solid #cc0000;"><code>$1</code></pre>')
      .replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2" style="color:#cc0000;border-bottom:1px solid #cc0000;">$1</a>')
      .replace(/^> (.*$)/gim, '<blockquote>$1</blockquote>')
      .replace(/^- (.*$)/gim, '<li>$1</li>')
      .replace(/\n/gim, '<br>');
    
    previewContent.innerHTML = html;
    preview.style.display = 'block';
    preview.scrollIntoView({ behavior: 'smooth' });
  });
  
  function generateSlug(title) {
    return title.toLowerCase()
      .replace(/[^\w\s-]/g, '')
      .replace(/\s+/g, '-')
      .substring(0, 50);
  }

  // 图片压缩工具
  function compressImage(file, maxWidth, maxHeight, quality) {
    return new Promise(function(resolve, reject) {
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          var canvas = document.createElement('canvas');
          var ctx = canvas.getContext('2d');
          var w = img.width;
          var h = img.height;
          if (w > h) {
            if (w > maxWidth) { h = Math.round(h * maxWidth / w); w = maxWidth; }
          } else {
            if (h > maxHeight) { w = Math.round(w * maxHeight / h); h = maxHeight; }
          }
          canvas.width = w;
          canvas.height = h;
          ctx.drawImage(img, 0, 0, w, h);
          var dataUrl = canvas.toDataURL('image/jpeg', quality);
          resolve(dataUrl.split(',')[1]);
        };
        img.onerror = reject;
        img.src = e.target.result;
      };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  // 图片上传
  var imageInput = document.getElementById('image-input');
  var uploadBtn = document.getElementById('upload-btn');
  var uploadStatus = document.getElementById('upload-status');
  var imagePreview = document.getElementById('image-preview');

  uploadBtn.addEventListener('click', function() {
    imageInput.click();
  });

  imageInput.addEventListener('change', async function() {
    var files = imageInput.files;
    if (!files.length) return;
    if (!pwdInput.value) {
      uploadStatus.textContent = '❌ 先填写发布密码';
      uploadStatus.style.color = '#cc0000';
      return;
    }

    uploadStatus.textContent = '准备处理 ' + files.length + ' 张图片...';
    uploadStatus.style.color = '#000';
    uploadBtn.disabled = true;

    for (var i = 0; i < files.length; i++) {
      var file = files[i];
      if (!file.type.startsWith('image/')) {
        uploadStatus.textContent = '❌ ' + file.name + ' 不是图片';
        uploadStatus.style.color = '#cc0000';
        continue;
      }

      uploadStatus.textContent = '正在压缩: ' + file.name + ' (' + Math.round(file.size/1024/1024*10)/10 + 'MB)';

      try {
        var base64 = await compressImage(file, 1920, 1920, 0.8);
        var compressedSize = Math.round(base64.length * 0.75 / 1024);

        uploadStatus.textContent = '上传中: ' + file.name + ' (约 ' + compressedSize + 'KB)';

        var res = await fetch('/api/upload-image', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            filename: file.name.replace(/\.[^/.]+$/, '') + '.jpg',
            content: base64,
            password: pwdInput.value
          })
        });

        var data = await res.json();
        if (!data.success) {
          uploadStatus.textContent = '❌ ' + file.name + ' 失败: ' + (data.error || '未知错误');
          uploadStatus.style.color = '#cc0000';
          continue;
        }

        // 自动填入顶图（第一张图且顶图框为空时）
        var heroInput = document.getElementById('heroImage');
        if (!heroInput.value) {
          heroInput.value = data.url;
        }

        var md = '\n![' + file.name + '](' + data.url + ')\n';
        var start = textarea.selectionStart;
        var end = textarea.selectionEnd;
        textarea.value = textarea.value.slice(0, start) + md + textarea.value.slice(end);
        textarea.focus();
        textarea.setSelectionRange(start + md.length, start + md.length);

        var thumb = document.createElement('div');
        thumb.style.width = '80px';
        thumb.style.height = '80px';
        thumb.style.background = 'url(' + data.url + ') center/cover';
        thumb.style.border = '2px solid #000';
        thumb.title = data.name;
        imagePreview.appendChild(thumb);
        
        uploadStatus.textContent = '✅ ' + file.name + ' 上传成功';

      } catch (err) {
        uploadStatus.textContent = '❌ ' + file.name + ' 错误: ' + err.message;
        uploadStatus.style.color = '#cc0000';
      }
    }

    uploadBtn.disabled = false;
    imageInput.value = '';
  });
  
  // 发布文章
  document.getElementById('post-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var status = document.getElementById('status');
    var btn = e.target.querySelector('button[type="submit"]');
    
    var title = document.getElementById('title').value.trim();
    var slug = document.getElementById('slug').value.trim() || generateSlug(title);
    var date = document.getElementById('date').value;
    var tags = document.getElementById('tags').value.split(',').map(function(t){ return t.trim(); }).filter(function(t){ return t; });
    var content = textarea.value;
    var password = pwdInput.value;
    var heroImage = document.getElementById('heroImage').value.trim();
    
    if (!slug.endsWith('.md')) slug += '.md';
    
    btn.disabled = true;
    btn.textContent = '发布中...';
    status.style.display = 'block';
    status.style.background = '#f5f5f5';
    status.style.color = '#000';
    status.innerHTML = '正在提交到 GitHub...';
    
    try {
      var res = await fetch('/api/publish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          title: title, 
          slug: slug, 
          date: date, 
          tags: tags, 
          content: content, 
          password: password,
          heroImage: document.getElementById('heroImage').value.trim(),
          hidden: document.getElementById('hidden').checked
        })
      });
      
      var data = await res.json();
      if (!res.ok) throw new Error(data.error || '发布失败');
      
      status.style.background = '#000';
      status.style.color = '#fff';
      var isHidden = document.getElementById('hidden').checked;
      var viewPath = isHidden ? '/secret/' : '/blog/';
      var viewUrl = viewPath + slug.replace('.md', '') + '/';

      status.innerHTML = '✅ 发布成功！<<br>文件路径：' + data.path + '<br>Cloudflare 正在自动构建，约 1-2 分钟后上线。<br><a href="' + viewUrl + '" style="color:#cc0000;">→ 查看文章</a>';
      e.target.reset();
      updatePublishTime();
      document.getElementById('preview').style.display = 'none';
      document.getElementById('heroImage').value = '';
      imagePreview.innerHTML = '';
    } catch (err) {
      status.style.background = '#cc0000';
      status.style.color = '#fff';
      status.innerHTML = '❌ 错误：' + err.message + '<br><small style="opacity:0.8;">检查密码是否正确，或 GitHub Token 是否已绑定</small>';
    } finally {
      btn.disabled = false;
      btn.textContent = '🚀 发布';
    }
  });
</script>