---
import Layout from '../layouts/BlogPost.astro';
---

<Layout title="秘密空间">
  <!-- 有权限：显示内容 -->
  <main id="collection-main" style="max-width:960px;margin:0 auto;padding:2rem 1rem; display:none;">
    <h1 style="border-bottom:3px solid #cc0000;padding-bottom:0.5rem;margin-bottom:1rem;">🎴 秘密空间</h1>
    <p style="color:#666;margin-bottom:2rem;font-style:italic;">"嘘，别乱说哦"</p>
    
    <div id="posts-loading" style="color:#999;">加载中...</div>
    <ul id="posts-container" style="display:flex;flex-wrap:wrap;gap:2rem;list-style:none;margin:0;padding:0;"></ul>
    
    <div style="margin-top:3rem;text-align:center;">
      <a href="/" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;border:2px solid #000;font-weight:700;text-decoration:none;">← 返回地面</a>
    </div>
  </main>
  
  <!-- 无权限：止步 -->
  <div id="collection-blocked" style="max-width:600px;margin:4rem auto;padding:2rem 1rem;text-align:center; display:none;">
    <h1 style="border-bottom:3px solid #cc0000;padding-bottom:0.5rem;margin-bottom:1.5rem;">🚫 止步</h1>
    <p style="color:#666;margin-bottom:2rem;">此路不通。</p>
    <a href="/" style="display:inline-block;padding:0.6rem 1.5rem;background:#000;color:#fff;border:2px solid #000;font-weight:700;text-decoration:none;">← 返回首页</a>
  </div>
</Layout>

<script is:inline>
(function() {
  var SECRET_KEY = 'sk_';
  
  function getKey() {
    return sessionStorage.getItem(SECRET_KEY) || localStorage.getItem(SECRET_KEY);
  }
  
  function saveKey(key) {
    sessionStorage.setItem(SECRET_KEY, key);
    localStorage.setItem(SECRET_KEY, key);
  }
  
  function showMain() {
    document.getElementById('collection-main').style.display = 'block';
    document.getElementById('collection-blocked').style.display = 'none';
  }
  
  function showBlocked() {
    document.getElementById('collection-main').style.display = 'none';
    document.getElementById('collection-blocked').style.display = 'block';
  }
  
  function renderPosts(posts) {
    var container = document.getElementById('posts-container');
    var loading = document.getElementById('posts-loading');
    loading.style.display = 'none';
    
    if (!posts || !posts.length) {
      container.innerHTML = '<p style="color:#999;">这里还没有秘密...</p>';
      return;
    }
    
    var html = '';
    for (var i = 0; i < posts.length; i++) {
      var post = posts[i];
      var width = i === 0 ? '100%' : 'calc(50% - 1rem)';
      var titleSize = i === 0 ? '2.369rem' : '1.2rem';
      var imgStyle = i === 0 ? 'max-height:400px;object-fit:cover;' : '';
      
      html += '<li style="width: ' + width + '; margin-bottom: 1rem;">';
      html += '<a href="/collection/' + post.id + '/" style="display:block;text-decoration:none;color:#000;">';
      if (post.heroImage) {
        html += '<img src="' + post.heroImage + '" alt="" style="width:100%;border-radius:12px;margin-bottom:0.5rem;' + imgStyle + '" />';
      }
      html += '<h4 style="margin:0;font-size:' + titleSize + ';line-height:1;">' + (post.title || post.id) + '</h4>';
      if (post.pubDate) {
        html += '<p style="margin:0.3rem 0 0;color:rgb(var(--gray));">' + new Date(post.pubDate).toLocaleDateString('zh-CN') + '</p>';
      }
      if (post.tags && post.tags.length) {
        html += '<div style="margin-top:0.5rem;display:flex;gap:0.4rem;flex-wrap:wrap;">';
        for (var j = 0; j < post.tags.length; j++) {
          html += '<span style="display:inline-block;padding:0.15rem 0.5rem;border:1px solid #000;color:#000;font-size:0.75rem;font-weight:600;">' + post.tags[j] + '</span>';
        }
        html += '</div>';
      }
      html += '</a></li>';
    }
    container.innerHTML = html;
  }
  
  // 主逻辑
  var key = getKey();
  console.log('collection page - key:', key ? 'exists' : 'missing');
  
  if (!key) {
    showBlocked();
  } else {
    loadPosts(key);
  }
  
  function loadPosts(key) {
    showMain();
    fetch('/api/secret-posts?key=' + encodeURIComponent(key))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) {
          // 秘钥无效，清除
          sessionStorage.removeItem(SECRET_KEY);
          localStorage.removeItem(SECRET_KEY);
          showBlocked();
          return;
        }
        renderPosts(data.posts);
      })
      .catch(function() {
        document.getElementById('posts-loading').textContent = '加载失败';
      });
  }
})();
</script>
