---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <p class="copyright">&copy; {today.getFullYear()} Moskavis. All rights reserved.</p>
    <div class="contact-links">
      <a href="https://www.xiaoheihe.cn/bbs/user_profile_share?user_id=ec396c10622c&h_src=heyboxapp" target="_blank" rel="noopener noreferrer">
        <span>📦 小黑盒</span>
      </a>
      <a href="Neil100o@foxmail.com">
        <span>✉️ 邮箱</span>
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 4rem;
    padding: 2rem 1rem;
    border-top: 2px solid #000;
    background: #fff;
  }
  
  .footer-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .copyright {
    font-size: 0.85rem;
    font-weight: 600;
    color: #555;
    margin: 0;
  }
  
  .contact-links {
    display: flex;
    gap: 1.5rem;
  }
  
  .contact-links a {
    color: #000;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    font-weight: 700;
    font-size: 0.9rem;
    transition: all 0.2s;
    padding-bottom: 0.2rem;
  }
  
  .contact-links a:hover {
    color: #cc0000;
    border-bottom-color: #cc0000;
  }
  
  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>