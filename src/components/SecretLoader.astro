---
interface Props {
  id: string;
  label: string;
  compact?: boolean;
}

const { id, label, compact = false } = Astro.props;
---

<div id={id} class:list={['secret-loader', { compact }]} role="status" aria-live="polite">
  <div class="orbit-field" aria-hidden="true">
    <span class="orbit orbit-one"></span>
    <span class="orbit orbit-two"></span>
    <span class="orbit orbit-three"></span>
    <span class="orbit-star">★</span>
    <span class="orbit-core"></span>
  </div>
  <p class="loader-code">SECURE CHANNEL</p>
  <p class="loader-label">
    {label}<span class="loading-dots" aria-hidden="true"><i></i><i></i><i></i></span>
  </p>
</div>

<style>
  .secret-loader {
    --loader-size: 164px;
    width: min(440px, calc(100% - 2rem));
    margin: 3rem auto;
    padding: 2rem 1.25rem;
    box-sizing: border-box;
    text-align: center;
    color: #d9e8f2;
    background:
      linear-gradient(rgba(92, 145, 175, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(92, 145, 175, 0.08) 1px, transparent 1px),
      #07131e;
    background-size: 22px 22px;
    border: 2px solid #142f42;
    box-shadow: 7px 7px 0 #02070c;
  }

  .secret-loader.compact {
    --loader-size: 112px;
    width: 100%;
    margin: 0;
    padding: 1.2rem;
    box-shadow: none;
  }

  .orbit-field {
    position: relative;
    width: var(--loader-size);
    height: var(--loader-size);
    margin: 0 auto 1rem;
  }

  .orbit,
  .orbit-star,
  .orbit-core {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%);
  }

  .orbit {
    border: 1px solid rgba(143, 194, 220, 0.45);
    border-left-color: #f2b544;
    border-radius: 50%;
    animation: orbit-turn 2.1s linear infinite;
  }

  .orbit-one { width: 92%; height: 38%; transform: translate(-50%, -50%) rotate(-24deg); }
  .orbit-two { width: 74%; height: 74%; animation-duration: 2.8s; animation-direction: reverse; }
  .orbit-three { width: 42%; height: 92%; transform: translate(-50%, -50%) rotate(36deg); animation-duration: 1.7s; }

  .orbit-star {
    width: 1.55rem;
    height: 1.55rem;
    color: #f4c44e;
    line-height: 1;
    text-shadow: 0 0 14px rgba(244, 196, 78, 0.85);
    animation: star-signal 1.2s ease-in-out infinite;
  }

  .orbit-core {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d9e8f2;
    box-shadow: 0 0 0 7px rgba(217, 232, 242, 0.08), 0 0 22px rgba(217, 232, 242, 0.7);
  }

  .loader-code {
    margin: 0 0 0.35rem;
    color: #f4c44e;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.2em;
  }

  .loader-label {
    margin: 0;
    color: #d9e8f2;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .loading-dots {
    display: inline-flex;
    gap: 0.2em;
    margin-left: 0.35em;
  }

  .loading-dots i {
    width: 0.28em;
    height: 0.28em;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.25;
    animation: dot-signal 1.05s ease-in-out infinite;
  }

  .loading-dots i:nth-child(2) { animation-delay: 0.16s; }
  .loading-dots i:nth-child(3) { animation-delay: 0.32s; }

  @keyframes orbit-turn {
    to { transform: translate(-50%, -50%) rotate(336deg); }
  }

  @keyframes star-signal {
    0%, 100% { transform: translate(-50%, -50%) scale(0.82); opacity: 0.65; }
    50% { transform: translate(-50%, -50%) scale(1.12); opacity: 1; }
  }

  @keyframes dot-signal {
    0%, 70%, 100% { opacity: 0.2; transform: translateY(0); }
    35% { opacity: 1; transform: translateY(-0.2em); }
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit,
    .orbit-star,
    .loading-dots i { animation-duration: 4s; }
  }
</style>
