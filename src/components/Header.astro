---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">首页</HeaderLink>
      <HeaderLink href="/blog">博客</HeaderLink>
      <HeaderLink href="/about">关于</HeaderLink>
      <HeaderLink href="/admin" class="admin-link">✎ 写作</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0;
    border-bottom: 2px solid #000;
    background: #fff;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 800px;
    margin: 0 auto;
    padding: 1.2rem 1rem;
  }

  h2 {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  h2 a {
    color: #000;
    text-decoration: none;
    border-bottom: none;
    transition: color 0.2s;
  }

  h2 a:hover {
    color: #cc0000;
  }

  .internal-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .internal-links :global(a) {
    display: inline-block;
    padding: 0.4rem 0.8rem;
    color: #000;
    text-decoration: none;
    border-bottom: 3px solid transparent;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s;
  }

  .internal-links :global(a:hover) {
    color: #cc0000;
    border-bottom-color: #cc0000;
  }

  .internal-links :global(a.active) {
    border-bottom-color: #000;
  }

  .internal-links :global(a.admin-link) {
    color: #cc0000;
    border: 2px solid #cc0000;
    padding: 0.3rem 0.7rem;
    margin-left: 0.5rem;
  }

  .internal-links :global(a.admin-link:hover) {
    background: #cc0000;
    color: #fff;
  }

  @media (max-width: 720px) {
    nav {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }

    .internal-links {
      flex-wrap: wrap;
    }
  }
</style>