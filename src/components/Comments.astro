<div id="comment-section" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #eee;">
	<div id="like-bar" style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 2px solid #000;">
		<button id="like-btn" style="padding: 0.5rem 1.2rem; background: #fff; color: #000; border: 2px solid #000; font-weight: 800; cursor: pointer; font-size: 1rem; display: flex; align-items: center; gap: 0.4rem;">
			<span id="like-icon">♥</span>
			<span id="like-count">加载中...</span>
		</button>
		<small style="color: #666;">觉得不错就点个赞吧</small>
	</div>
	<h3>评论</h3>

	<form id="cf" onsubmit="return false;" style="margin-bottom: 2rem;">
		<div style="display: flex; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
			<input name="author" placeholder="昵称 *" required="" style="padding: 0.5rem; width: 200px; border: 2px solid #000;" />
			<input type="email" name="email" placeholder="邮箱（选填）" style="padding: 0.5rem; width: 260px; border: 2px solid #000;" />
		</div>
		<textarea id="comment-textarea" name="content" placeholder="说点什么..." required="" style="padding: 0.5rem; width: 100%; min-height: 80px; margin-bottom: 0.5rem; border: 2px solid #000;"></textarea>
		<button type="submit" id="sb" style="padding: 0.5rem 1rem; background: #000; color: #fff; border: 2px solid #000; font-weight: 700; cursor: pointer;">提交评论</button>
	</form>

	<div id="cl">加载中...</div>
</div>