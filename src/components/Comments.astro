<div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #eee;">
	<h3>иҜ„и®ә</h3>

	<form id="comment-form" style="margin-bottom: 2rem;">
		<div style="margin-bottom: 0.5rem;">
			<input name="author" placeholder="жҳөз§°" required="" style="padding: 0.5rem; width: 200px;" />
		</div>
		<div style="margin-bottom: 0.5rem; position: relative;">
			<textarea id="comment-textarea" name="content" placeholder="иҜҙзӮ№д»Җд№Ҳ..." required="" style="padding: 0.5rem; width: 100%; min-height: 80px;"></textarea>

			<!-- иЎЁжғ…йқўжқҝ -->
			<div style="margin-top: 0.5rem;">
				<button type="button" id="emoji-toggle" style="padding: 0.3rem 0.8rem; background: #f0f0f0; border: 1px solid #ccc; border-radius: 4px; cursor: pointer;">рҹҳҠ иЎЁжғ…</button>
				<div id="emoji-panel" style="display: none; margin-top: 0.5rem; padding: 0.8rem; background: #fafafa; border: 1px solid #ddd; border-radius: 6px; max-height: 220px; overflow-y: auto;">

					<div style="margin-bottom: 0.6rem;">
						<small style="color: #666; font-weight: bold;">Emoji</small>
						<div style="display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.3rem;">
							{['рҹҳҖ','рҹҳӮ','рҹӨЈ','рҹҳӯ','рҹҳҚ','рҹҘ°','рҹҳҳ','рҹҳЎ','рҹҘ¶','рҹӨЎ','рҹ‘Қ','рҹ‘Һ','рҹҷҸ','рҹ’Ә','рҹҺү','рҹ”Ҙ','рҹ’Җ','вҳ•','рҹҚә','рҹҚң','рҹҢ№','рҹҢҹ','вңЁ','вқӨпёҸ','рҹ’”','вҷ»пёҸ','рҹҮЁрҹҮі','вҳӯ'].map(e => (
							<button type="button" class="emoji-btn" data-char={"e"} style="padding: 0.2rem 0.4rem; background: white; border: 1px solid #e0e0e0; border-radius: 4px; cursor: pointer; font-size: 1.2rem;">{e}</button>
							))}
						</div>
					</div>

					<div style="margin-bottom: 0.6rem;">
						<small style="color: #666; font-weight: bold;">йўңж–Үеӯ—</small>
						<div style="display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.3rem;">
							{['(вҢ’в–ҪвҢ’)вҳҶ','(вү§в–ҪвүҰ)','(пҝЈв–ҪпҝЈ)','(пҪЎпҪҘПүпҪҘпҪЎ)','(ВҙпҪҘПүпҪҘ`)','(пҪҖгғ»Пүгғ»Вҙ)','(вңҝв—ЎвҖҝв—Ў)','(в•ҜВ°в–ЎВ°пјүв•Ҝпёө в”»в”Ғв”»','(в•Ҙп№Ҹв•Ҙ)','(пјӣВҙР”пҪҖ)','(пҝЈгғҳпҝЈ)','( пҫҹРҙпҫҹ)','(гғ»Пү<< )вҳ…','(Вҙ-О№_-пҪҖ)','(пҪЎЕҸ_ЕҸ)','(аёҮ вҖў_вҖў)аёҮ','( НЎВ° НңК– НЎВ°)','(вҳӯ НңК– вҳӯ)','(вңҝ вҷЎвҖҝвҷЎ)','(>Пү<<)','(ВҙпјӣПүпјӣ`)','(в•¬ Г’п№ҸГ“)','(пҫү*>вҲҖ<<)пҫүвҷЎ','(пҝЈп№ғпҝЈ='')','( гҒӨвҖўМҖПүвҖўМҒ)гҒӨ=''','(а№‘вҖўМҖг…ӮвҖўМҒ)ЩҲвң§=''','(В°гғјВ°гҖғ='')','( Вҙ_гӮқ`)'].map(k => (
                <button type="button" class="emoji-btn" data-char={"k"} style="padding: 0.2rem 0.5rem; background: white; border: 1px solid #e0e0e0; border-radius: 4px; cursor: pointer; font-size: 0.85rem; white-space: nowrap;">{k}</button>
							))}
						</div>
					</div>

				</div>
			</div>
		</div>
		<button type="submit" style="padding: 0.5rem 1rem;">жҸҗдәӨиҜ„и®ә</button>
	</form>

	<div id="comments-list">еҠ иҪҪдёӯ...</div>
</div>

<script is:inline="">
	const path = window.location.pathname;
	const textarea = document.getElementById('comment-textarea');

	// иЎЁжғ…йқўжқҝејҖе…і
	document.getElementById('emoji-toggle').addEventListener('click', () => {
	const panel = document.getElementById('emoji-panel');
	panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
	});

	// зӮ№еҮ»иЎЁжғ…жҸ’е…ҘеҲ°е…үж ҮдҪҚзҪ®
	document.getElementById('emoji-panel').addEventListener('click', (e) => {
	if (e.target.classList.contains('emoji-btn')) {
	const char = e.target.getAttribute('data-char');
	const start = textarea.selectionStart;
	const end = textarea.selectionEnd;
	const text = textarea.value;
	textarea.value = text.slice(0, start) + char + text.slice(end);
	textarea.focus();
	textarea.setSelectionRange(start + char.length, start + char.length);
	}
	});

	// еҠ иҪҪиҜ„и®ә
	fetch(`/api/comments?path=${encodeURIComponent(path)}`)
	.then(async r => {
	if (!r.ok) throw new Error('еҠ иҪҪеӨұиҙҘ: ' + r.status);
	return r.json();
	})
	.then(data => {
	const list = document.getElementById('comments-list');
	if (!data || !data.length) {
	list.innerHTML = '<p style="color: #999;">жҡӮж— иҜ„и®әпјҢжқҘжҠўжІҷеҸ‘еҗ§</p>';
	return;
	}
	list.innerHTML = data.map(c => `
	<div style="border-bottom: 1px solid #eee; padding: 1rem 0;">
		<div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
			<strong>${c.author}</strong>
			<small style="color: #999;">${new Date(c.created_at).toLocaleString('zh-CN')}</small>
		</div>
		<p style="margin: 0; white-space: pre-wrap;">${c.content}</p>
	</div>
	`).join('');
	})
	.catch(err => {
	document.getElementById('comments-list').innerHTML = `<p style="color: red;">иҜ„и®әеҠ иҪҪеӨұиҙҘ: ${err.message}</p>`;
	});

	// жҸҗдәӨ
	document.getElementById('comment-form').addEventListener('submit', async (e) => {
	e.preventDefault();
	const form = e.target;
	const btn = form.querySelector('button[type="submit"]');
	btn.disabled = true;
	btn.textContent = 'жҸҗдәӨдёӯ...';

	try {
	const res = await fetch(`/api/comments?path=${encodeURIComponent(path)}`, {
	method: 'POST',
	headers: { 'Content-Type': 'application/json' },
	body: JSON.stringify({
	author: form.author.value,
	content: textarea.value
	})
	});

	if (!res.ok) {
	const err = await res.json().catch(() => ({ error: 'жңӘзҹҘй”ҷиҜҜ' }));
	throw new Error(err.error || 'жҸҗдәӨеӨұиҙҘ');
	}

	form.reset();
	location.reload();
	} catch (err) {
	alert('жҸҗдәӨеӨұиҙҘ: ' + err.message);
	btn.disabled = false;
	btn.textContent = 'жҸҗдәӨиҜ„и®ә';
	}
	});
</script>