<div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #eee;">
	<h3>评论</h3>

	<form id="cf" onsubmit="return false;" style="margin-bottom: 2rem;">
		<div style="display: flex; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
			<input name="author" placeholder="昵称 *" required="" style="padding: 0.5rem; width: 200px; border: 2px solid #000;" />
			<input type="email" name="email" placeholder="邮箱（选填）" style="padding: 0.5rem; width: 260px; border: 2px solid #000;" />
		</div>
		<textarea id="tx" name="content" placeholder="说点什么..." required="" style="padding: 0.5rem; width: 100%; min-height: 80px; margin-bottom: 0.5rem; border: 2px solid #000;"></textarea>
		<button type="submit" id="sb" style="padding: 0.5rem 1rem; background: #000; color: #fff; border: 2px solid #000; font-weight: 700; cursor: pointer;">提交评论</button>
	</form>

	<div id="cl">加载中...</div>
</div>

<script is:inline="">
	(function(){
	var p = location.pathname;
	var tx = document.getElementById('tx');
	var cl = document.getElementById('cl');

	// 加载评论
	function load() {
	fetch('/api/comments?path=' + encodeURIComponent(p))
	.then(function(r){
	if(!r.ok) throw new Error('HTTP ' + r.status);
	return r.json();
	})
	.then(function(d){
	if(!d || !d.length){
	cl.innerHTML = '<p style="color:#999">暂无评论，来抢沙发吧</p>';
	return;
	}
	var h = '';
	for(var i = 0; i < d.length; i++){
          var c = d[i];
          var mail = c.email ? ' <small style="color:#999">(' + c.email + ')</small>' : '';
	h += '<div style="border-bottom:1px solid #eee;padding:1rem 0">
		' +
		'<div style="display:flex;justify-content:space-between;margin-bottom:0.5rem;flex-wrap:wrap">
			' +
			'<div>
				<strong>' + c.author + '</strong>' + mail + '
			</div>' +
			'<small style="color:#999">' + new Date(c.created_at).toLocaleString('zh-CN') + '</small>' +
			'
		</div>' +
		'<p style="margin:0;white-space:pre-wrap">' + c.content + '</p>' +
		'
	</div>';
	}
	cl.innerHTML = h;
	})
	.catch(function(e){
	cl.innerHTML = '<p style="color:red">加载失败: ' + e.message + '</p>';
	});
	}

	// 提交
	var form = document.getElementById('cf');
	var btn = document.getElementById('sb');

	form.addEventListener('submit', function(e){
	e.preventDefault();
	e.stopPropagation();

	btn.disabled = true;
	btn.textContent = '提交中...';

	fetch('/api/comments?path=' + encodeURIComponent(p), {
	method: 'POST',
	headers: {'Content-Type': 'application/json'},
	body: JSON.stringify({
	author: form.author.value,
	email: form.email.value,
	content: tx.value
	})
	})
	.then(function(r){
	if(!r.ok){
	return r.json().then(function(err){ throw new Error(err.error || '提交失败'); });
	}
	return r.json();
	})
	.then(function(){
	form.reset();
	load(); // 不刷新页面，直接重新加载评论
	})
	.catch(function(err){
	alert('提交失败: ' + err.message);
	btn.disabled = false;
	btn.textContent = '提交评论';
	});

	return false; // 三重保险
	});

	load();
	})();
</script>