<div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #eee;">
	<h3>评论</h3>

	<form id="comment-form" style="margin-bottom: 2rem;">
		<div style="margin-bottom: 0.5rem;">
			<input name="author" placeholder="昵称" required="" style="padding: 0.5rem; width: 200px;" />
		</div>
		<div style="margin-bottom: 0.5rem; position: relative;">
			<textarea id="comment-textarea" name="content" placeholder="说点什么..." required="" style="padding: 0.5rem; width: 100%; min-height: 80px;"></textarea>

			<div style="margin-top: 0.5rem;">
				<button type="button" id="emoji-toggle" style="padding: 0.3rem 0.8rem; background: #f0f0f0; border: 1px solid #ccc; border-radius: 4px; cursor: pointer;">😊 表情</button>
				<div id="emoji-panel" style="display: none; margin-top: 0.5rem; padding: 0.8rem; background: #fafafa; border: 1px solid #ddd; border-radius: 6px; max-height: 220px; overflow-y: auto;">
					<div id="emoji-container"></div>
				</div>
			</div>
		</div>
		<button type="submit" style="padding: 0.5rem 1rem;">提交评论</button>
	</form>

	<div id="comments-list">加载中...</div>
</div>

<script is:inline="">
	const path = window.location.pathname;
	const textarea = document.getElementById('comment-textarea');

	// 表情数据
	const emojis = ['😀','😂','🤣','😭','😍','🥰','😘','😡','🥶','🤡','👍','👎','🙏','💪','🎉','🔥','💀','☕','🍺','🍜','🌹','🌟','✨','❤️','💔','♻️','🇨🇳','☭'];
	const kaomojis = ['(⌒▽⌒)☆','(≧▽≦)','(￣▽￣)','(｡･ω･｡)','(´･ω･`)','(｀・ω・´)','(✿◡‿◡)','(╯°□°）╯︵ ┻━┻','(╥﹏╥)','(；´Д｀)','(￣ヘ￣)','( ﾟдﾟ)','(・ω<< )★','(´-ι_-｀)','(｡ŏ_ŏ)','(ง •_•)ง','( ͡° ͜ʖ ͡°)','(☭ ͜ʖ ☭)','(✿ ♡‿♡)','(>ω<<)','(´；ω；`)','(╬ Ò﹏Ó)','(ﾉ*>∀<<)ﾉ♡','(￣﹃￣='')','( つ•̀ω•́)つ=''','(๑•̀ㅂ•́)و✧=''','(°ー°〃=''

  // 生成表情面板
  const container = document.getElementById('emoji-container=''');
  
  let html = '<div style="margin-bottom:0.6rem;">
		<small style="color:#666;font-weight:bold;">Emoji</small>
		<div style="display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.3rem;">
			';
			emojis.forEach(function(e) {
			html += '<button type="button" class="emoji-btn" data-char="' + e + '" style="padding:0.2rem 0.4rem;background:white;border:1px solid #e0e0e0;border-radius:4px;cursor:pointer;font-size:1.2rem;">' + e + '</button>';
			});
			html += '
		</div>
	</div>';

	html += '<div style="margin-bottom:0.6rem;">
		<small style="color:#666;font-weight:bold;">颜文字</small>
		<div style="display:flex;flex-wrap:wrap;gap:0.3rem;margin-top:0.3rem;">
			';
			kaomojis.forEach(function(k) {
			html += '<button type="button" class="emoji-btn" data-char="' + k.replace(/"/g, '&quot;') + '" style="padding:0.2rem 0.5rem;background:white;border:1px solid #e0e0e0;border-radius:4px;cursor:pointer;font-size:0.85rem;white-space:nowrap;">' + k + '</button>';
			});
			html += '
		</div>
	</div>';

	container.innerHTML = html;

	// 表情面板开关
	document.getElementById('emoji-toggle').addEventListener('click', function() {
	const panel = document.getElementById('emoji-panel');
	panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
	});

	// 点击表情插入到光标位置
	document.getElementById('emoji-panel').addEventListener('click', function(e) {
	if (e.target.classList.contains('emoji-btn')) {
	const char = e.target.getAttribute('data-char');
	const start = textarea.selectionStart;
	const end = textarea.selectionEnd;
	const text = textarea.value;
	textarea.value = text.slice(0, start) + char + text.slice(end);
	textarea.focus();
	textarea.setSelectionRange(start + char.length, start + char.length);
	}
	});

	// 加载评论
	fetch('/api/comments?path=' + encodeURIComponent(path))
	.then(async function(r) {
	if (!r.ok) throw new Error('加载失败: ' + r.status);
	return r.json();
	})
	.then(function(data) {
	const list = document.getElementById('comments-list');
	if (!data || !data.length) {
	list.innerHTML = '<p style="color: #999;">暂无评论，来抢沙发吧</p>';
	return;
	}
	list.innerHTML = data.map(function(c) {
	return '<div style="border-bottom: 1px solid #eee; padding: 1rem 0;">
		' +
		'<div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
			' +
			'<strong>' + c.author + '</strong>' +
			'<small style="color: #999;">' + new Date(c.created_at).toLocaleString('zh-CN') + '</small>' +
			'
		</div>' +
		'<p style="margin: 0; white-space: pre-wrap;">' + c.content + '</p>' +
		'
	</div>';
	}).join('');
	})
	.catch(function(err) {
	document.getElementById('comments-list').innerHTML = '<p style="color: red;">评论加载失败: ' + err.message + '</p>';
	});

	// 提交
	document.getElementById('comment-form').addEventListener('submit', async function(e) {
	e.preventDefault();
	const form = e.target;
	const btn = form.querySelector('button[type="submit"]');

	btn.disabled = true;
	btn.textContent = '提交中...';

	try {
	const res = await fetch('/api/comments?path=' + encodeURIComponent(path), {
	method: 'POST',
	headers: { 'Content-Type': 'application/json' },
	body: JSON.stringify({
	author: form.author.value,
	content: textarea.value
	})
	});

	if (!res.ok) {
	const err = await res.json().catch(function() { return { error: '未知错误' }; });
	throw new Error(err.error || '提交失败');
	}

	form.reset();
	location.reload();
	} catch (err) {
	alert('提交失败: ' + err.message);
	btn.disabled = false;
	btn.textContent = '提交评论';
	}
	});
</script>