<div id="blog-launch-intro" class="launch-intro" role="dialog" aria-modal="true" aria-label="正在进入 Mo Blog">
  <button id="launch-intro-skip" class="intro-skip" type="button">跳过</button>

  <svg class="launch-map" viewBox="0 0 1000 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <linearGradient id="mainTrail" x1="0" y1="1" x2="1" y2="0">
        <stop offset="0" stop-color="#fff3c9" />
        <stop offset="0.64" stop-color="#ffe79a" />
        <stop offset="1" stop-color="#f2b42f" />
      </linearGradient>
      <linearGradient id="sideTrail" x1="0" y1="1" x2="1" y2="0">
        <stop offset="0" stop-color="#fff8df" />
        <stop offset="0.72" stop-color="#ffe58d" />
        <stop offset="1" stop-color="#efad26" />
      </linearGradient>
      <filter id="fixedStarGlow" x="-130%" y="-130%" width="360%" height="360%">
        <feGaussianBlur stdDeviation="8" result="blur" />
        <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
      </filter>
      <mask id="trailReveal" maskUnits="userSpaceOnUse" x="0" y="0" width="1000" height="700">
        <rect width="1000" height="700" fill="#000" />
        <path
          class="reveal-path"
          pathLength="1"
          d="M 42 680 C 250 659 414 555 548 405 C 680 257 792 124 908 34"
          fill="none"
          stroke="#fff"
          stroke-width="390"
          stroke-linecap="round"
        />
      </mask>
    </defs>

    <g class="trail-fields" mask="url(#trailReveal)">
      <path
        class="main-ribbon"
        d="M 22 671 C 224 650 402 557 548 402 C 683 259 798 119 908 34
           L 858 186 C 770 283 688 377 605 472 C 463 634 282 690 64 704 Z"
      />
      <path
        class="side-ribbon"
        d="M 553 706 C 520 619 552 527 620 424 C 718 277 814 132 908 34
           L 869 186 C 792 302 721 414 656 522 C 598 619 582 674 590 706 Z"
      />
      <path class="main-red-line" d="M 72 692 C 270 655 421 555 548 410 C 671 268 786 133 900 42" />
      <path class="side-red-line" d="M 574 699 C 552 620 581 531 641 434 C 732 286 817 143 900 42" />
      <path class="gold-edge" d="M 30 681 C 240 655 408 553 548 402 C 683 257 798 119 908 34" />
    </g>

    <g class="flight-star" filter="url(#fixedStarGlow)">
      <g transform="rotate(42)">
        <polygon points="0,-27 7,-9 27,-9 11,3 17,23 0,12 -17,23 -11,3 -27,-9 -7,-9" />
      </g>
      <animateMotion
        path="M 42 680 C 250 659 414 555 548 405 C 680 257 792 124 908 34"
        begin="0.24s"
        dur="2.55s"
        fill="freeze"
        calcMode="spline"
        keyTimes="0;1"
        keySplines="0.32 0.04 0.1 1"
        rotate="0"
      />
    </g>
  </svg>
</div>

<script is:inline>
(function() {
  var intro = document.getElementById('blog-launch-intro');
  var skip = document.getElementById('launch-intro-skip');
  if (!intro) return;

  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var seen = false;
  try { seen = sessionStorage.getItem('blog_launch_seen') === '1'; } catch (e) {}

  if (seen || reduceMotion) {
    try { sessionStorage.setItem('blog_launch_seen', '1'); } catch (e) {}
    intro.remove();
    return;
  }

  try { sessionStorage.setItem('blog_launch_seen', '1'); } catch (e) {}
  document.documentElement.classList.add('blog-intro-active');

  var finished = false;
  function finishIntro() {
    if (finished) return;
    finished = true;
    intro.classList.add('is-leaving');
    document.documentElement.classList.remove('blog-intro-active');
    setTimeout(function() { intro.remove(); }, 380);
  }

  skip.addEventListener('click', finishIntro);
  setTimeout(finishIntro, 3400);
})();
</script>

<style>
  .launch-intro {
    position: fixed;
    inset: 0;
    z-index: 20000;
    overflow: hidden;
    background:
      radial-gradient(circle at 13% 88%, rgba(18, 54, 77, 0.62), transparent 34%),
      linear-gradient(145deg, #071522, #02070c 72%);
    opacity: 1;
    transition: opacity 320ms ease, visibility 320ms ease;
  }

  .launch-intro::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.12;
    background-image: linear-gradient(rgba(171, 202, 217, 0.12) 1px, transparent 1px);
    background-size: 100% 6px;
  }

  .launch-intro.is-leaving {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .launch-map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .reveal-path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: reveal-trajectory 2.58s 0.2s cubic-bezier(0.32, 0.04, 0.1, 1) forwards;
  }

  .main-ribbon {
    fill: url(#mainTrail);
    stroke: #f5bf28;
    stroke-width: 7;
    stroke-linejoin: round;
  }

  .side-ribbon {
    fill: url(#sideTrail);
    stroke: #ffd122;
    stroke-width: 8;
    stroke-linejoin: round;
  }

  .main-red-line,
  .side-red-line,
  .gold-edge {
    fill: none;
    stroke-linecap: round;
  }

  .main-red-line,
  .side-red-line {
    stroke: #d9472b;
    stroke-width: 4;
  }

  .gold-edge {
    stroke: #ffc91e;
    stroke-width: 7;
  }

  .flight-star {
    fill: #f3b72f;
    opacity: 0;
    animation: fixed-star-show 2.72s 0.2s ease forwards;
  }

  .intro-skip {
    position: absolute;
    z-index: 3;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    padding: 0.5rem 0.9rem;
    color: rgba(220, 233, 239, 0.72);
    background: rgba(2, 7, 12, 0.55);
    border: 1px solid rgba(143, 176, 193, 0.5);
    font: inherit;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
  }

  .intro-skip:hover,
  .intro-skip:focus-visible {
    color: #071522;
    background: #fff3c9;
    border-color: #fff3c9;
  }

  @keyframes reveal-trajectory {
    to { stroke-dashoffset: 0; }
  }

  @keyframes fixed-star-show {
    0%, 2% { opacity: 0; }
    10%, 86% { opacity: 1; }
    100% { opacity: 0; }
  }

  @media (max-width: 720px) {
    .launch-map {
      width: 142%;
      height: 108%;
      left: -35%;
      top: -5%;
    }
  }
</style>

<style is:global>
  html.blog-intro-active,
  html.blog-intro-active body {
    overflow: hidden;
  }
</style>
